# --- Supabase (project MUST be created in EU / Frankfurt, eu-central-1 — cannot change region later) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=      # server-side only, NEVER exposed to client, NEVER NEXT_PUBLIC_*

# --- Launch token signing (scoped cmi5 JWT, distinct from Supabase auth JWT) ---
LAUNCH_JWT_SECRET=

# --- Origins (three-layer trust boundary, see docs and bestilling §3) ---
APP_ORIGIN=https://app.tinkrakademiet.no
PLAYER_ORIGIN=https://player.tinkrakademiet.no

# --- LRS ---
LRS_ENDPOINT=                   # base URL for the xAPI endpoint, e.g. https://app.tinkrakademiet.no/api/xapi/

# --- cmi5 publisher/versioning (MUST match Tinkr Studio's VITE_PUBLISHER_BASE) ---
PUBLISHER_BASE=https://tinkrakademiet.no/xapi

# --- Session / token policy (bestilling §9b, confirmed as-is) ---
SESSION_MAX_HOURS=8
SESSION_IDLE_TIMEOUT_HOURS=2
LAUNCH_TOKEN_TTL_HOURS=12
CORS_ACCESS_CONTROL_MAX_AGE_SECONDS=7200

# --- Next.js public (client-safe) values ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_ORIGIN=https://app.tinkrakademiet.no
NEXT_PUBLIC_PLAYER_ORIGIN=https://player.tinkrakademiet.no
